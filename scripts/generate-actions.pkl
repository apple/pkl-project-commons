import "@com.github.actions.contrib/ActionGenerator.pkl"

local setupGradleGenerator: ActionGenerator = new {
  actionName = "gradle/actions/setup-gradle@v6"
  githubActionsPackageName = "@com.github.actions"
}

local dependencySubmissionGenerator: ActionGenerator = new {
  actionName = "gradle/actions/dependency-submission@v6"
  githubActionsPackageName = "@com.github.actions"
}

output {
  files {
    ["packages/pkl.impl.ghactions/actions/gradle/actions/setup-gradle/v6/SetupGradle.pkl"] {
      text = setupGradleGenerator.result
    }
    ["packages/pkl.impl.ghactions/actions/gradle/actions/dependency-submission/v6/DependencySubmission.pkl"] {
      text = dependencySubmissionGenerator.result
    }
  }
}
